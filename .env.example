# Optional: trigger spreadsheet/CRM automation through a webhook.
# Example: Zapier, Make, Google Apps Script, or another backend that can save to Google Sheets/Airtable.
SUBMISSION_NOTIFICATION_WEBHOOK_URL=

# Production CSV storage on Vercel Blob. Required for durable production storage.
BLOB_READ_WRITE_TOKEN=

# Optional: send Creative Care submission notifications directly through Resend.
RESEND_API_KEY=
SUBMISSION_NOTIFICATION_FROM="Creative Solutions Partners <notifications@creativesolutionspartners.com>"
